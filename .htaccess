# Enable rewriting
RewriteEngine On
RewriteOptions Inherit

# --- SECURITY ---
# Block access to sensitive files
RedirectMatch 404 /\.git
RedirectMatch 404 secrets.env

# --- MEDIAWIKI: allow direct img_auth access ---
RewriteCond %{REQUEST_URI} ^/img_auth\.php/
RewriteRule ^ - [L]

# --- MEDIAWIKI SHORT URL HANDLING ---
# If request is NOT a real file or directory, send to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Exclude REST API (must NOT be rewritten)
RewriteRule ^rest\.php/ - [L]

# Main rewrite rule
RewriteRule ^(.*)$ index.php [L]

# --- ROOT REQUEST ---
# Redirect root to index.php explicitly
RewriteRule ^$ index.php [L]
